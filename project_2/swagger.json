  },
  "components": {
    "schemas": {
      "Game": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Auto-generated MongoDB ID"
          },
          "title": {
            "type": "string",
            "description": "Game title"
          },
          "genre": {
            "type": "string",
            "description": "Game genre",
            "enum": ["Action", "Adventure", "RPG", "Shooter", "Sports", "Strategy", "Simulation", "Puzzle", "Platformer", "Fighting", "Racing", "Horror"]
          },
          "releaseYear": {
            "type": "integer",
            "description": "Year the game was released"
          },
          "developer": {
            "type": "string",
            "description": "Game developer/studio"
          },
          "rating": {
            "type": "number",
            "description": "Game rating (0-10)"
          },
          "isMultiplayer": {
            "type": "boolean",
            "description": "Whether the game supports multiplayer"
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Platforms the game is available on"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the game was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the game was last updated"
          }
        }
      },
      "GameInput": {
        "type": "object",
        "required": ["title", "genre", "releaseYear", "developer", "rating", "isMultiplayer", "platforms"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Game title",
            "example": "The Legend of Zelda: Tears of the Kingdom"
          },
          "genre": {
            "type": "string",
            "description": "Game genre",
            "enum": ["Action", "Adventure", "RPG", "Shooter", "Sports", "Strategy", "Simulation", "Puzzle", "Platformer", "Fighting", "Racing", "Horror"],
            "example": "Adventure"
          },
          "releaseYear": {
            "type": "integer",
            "description": "Year the game was released",
            "example": 2023
          },
          "developer": {
            "type": "string",
            "description": "Game developer/studio",
            "example": "Nintendo"
          },
          "rating": {
            "type": "number",
            "description": "Game rating (0-10)",
            "example": 9.5
          },
          "isMultiplayer": {
            "type": "boolean",
            "description": "Whether the game supports multiplayer",
            "example": false
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Platforms the game is available on",
            "example": ["Nintendo Switch"]
          }
        }
      },
      "Console": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Auto-generated MongoDB ID"
          },
          "name": {
            "type": "string",
            "description": "Console name"
          },
          "manufacturer": {
            "type": "string",
            "description": "Console manufacturer"
          },
          "releaseYear": {
            "type": "integer",
            "description": "Year the console was released"
          },
          "generation": {
            "type": "integer",
            "description": "Console generation (1-10)"
          },
          "isPortable": {
            "type": "boolean",
            "description": "Whether the console is portable/handheld"
          },
          "unitsSold": {
            "type": "number",
            "description": "Units sold in millions"
          },
          "discontinued": {
            "type": "boolean",
            "description": "Whether the console is discontinued"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the console was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the console was last updated"
          }
        }
      },
      "ConsoleInput": {
        "type": "object",
        "required": ["name", "manufacturer", "releaseYear", "generation", "isPortable"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Console name (must be unique)",
            "example": "Nintendo Switch"
          },
          "manufacturer": {
            "type": "string",
            "description": "Console manufacturer",
            "example": "Nintendo"
          },
          "releaseYear": {
            "type": "integer",
            "description": "Year the console was released",
            "example": 2017
          },
          "generation": {
            "type": "integer",
            "description": "Console generation (1-10)",
            "example": 8
          },
          "isPortable": {
            "type": "boolean",
            "description": "Whether the console is portable/handheld",
            "example": true
          },
          "unitsSold": {
            "type": "number",
            "description": "Units sold in millions (optional)",
            "example": 125
          },
          "discontinued": {
            "type": "boolean",
            "description": "Whether the console is discontinued (optional)",
            "example": false
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Error message description"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Validation error"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["Game title is required", "Rating cannot exceed 10"]
          }
        }
      }
    }
  }
}